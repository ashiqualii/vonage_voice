<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Full-screen dark theme for IncomingCallActivity.
         Uses transparent background + windowDisablePreview to match Twilio's
         proven lock-screen-compatible theme on Samsung A15 / Android 16. -->
    <style name="Theme.VonageIncomingCall" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Invisible transparent theme for AnswerCallTrampolineActivity -->
    <style name="Theme.VonageTransparent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Bottom sheet text styles -->
    <style name="answer_call">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#A1A1AA</item>
    </style>

    <style name="put_1_222_3">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FAFAFA</item>
    </style>

    <style name="end_call_wi">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FAFAFA</item>
    </style>

    <style name="decline_inc">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#A1A1AA</item>
    </style>

</resources>
